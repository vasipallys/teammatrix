# NextGen Organization Visualizer Frontend - Environment Configuration Template
# Copy this file to .env.local and configure your values
# All variables must be prefixed with VITE_ to be accessible in the frontend

# =====================================
# API Configuration
# =====================================
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=30000

# =====================================
# WebSocket Configuration
# =====================================
VITE_WS_HOSTNAME=localhost
VITE_WS_PORT=5000
VITE_WS_RECONNECT_ATTEMPTS=5
VITE_WS_RECONNECT_DELAY=1000
VITE_WS_HEARTBEAT_INTERVAL=30000

# =====================================
# Application Settings
# =====================================
VITE_APP_TITLE=NextGen Organization Visualizer
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
VITE_DEBUG=false

# =====================================
# Data Synchronization
# =====================================
VITE_SYNC_INTERVAL=300000
VITE_ENABLE_AUTO_SYNC=true
VITE_SYNC_MAX_RETRIES=3

# =====================================
# Performance Monitoring
# =====================================
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_PERFORMANCE_SAMPLE_RATE=0.1
VITE_PERFORMANCE_REPORT_INTERVAL=60000

# =====================================
# Theme Configuration
# =====================================
VITE_DEFAULT_THEME=dark

# =====================================
# Feature Flags
# =====================================
VITE_ENABLE_COLLABORATION=true
VITE_ENABLE_REALTIME_SYNC=true
VITE_ENABLE_ADVANCED_ANALYTICS=true
VITE_ENABLE_EXPORT_FEATURES=true
VITE_ENABLE_LDAP=true
VITE_ENABLE_SAMPLE_DATA=true

# =====================================
# Chart Configuration (Legacy - still supported)
# =====================================
VITE_DEFAULT_COLOR_SCHEME=Set3
VITE_DEFAULT_COLOR_BY=Job Function
VITE_DEFAULT_CHART_TYPE=sunburst

# =====================================
# File Upload Configuration (Legacy - still supported)
# =====================================
VITE_MAX_FILE_SIZE=16777216

# =====================================
# Security Configuration
# =====================================
VITE_ENABLE_CSP=true
VITE_SESSION_TIMEOUT=3600000

# =====================================
# Logging Configuration
# =====================================
VITE_LOG_LEVEL=warn
VITE_ENABLE_REMOTE_LOGGING=false
VITE_REMOTE_LOG_ENDPOINT=

# For legacy logging service compatibility:
REACT_APP_LOG_LEVEL=INFO

# =====================================
# Analytics Configuration
# =====================================
VITE_ENABLE_ANALYTICS=false
VITE_ANALYTICS_TRACKING_ID=

# =====================================
# Development Settings
# =====================================
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEV_TOOLS=false
VITE_MOCK_DELAY=1000
VITE_DEV_MODE=false

# Node.js environment (automatically set by build tools)
# NODE_ENV=production

# =====================================
# Runtime Configuration Notes
# =====================================
# - All VITE_ variables are available at build time and runtime
# - REACT_APP_ variables are for legacy compatibility
# - NODE_ENV is automatically managed by build tools
# - Variables are validated on application startup
# - Missing optional variables will use default values
# - Check browser console for configuration warnings in development