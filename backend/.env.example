# NextGen Organization Visualizer Backend - Environment Configuration Template
# Copy this file to .env and configure your values

# =====================================
# Flask Configuration
# =====================================
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=false
FLASK_TESTING=false
SECRET_KEY=change-this-secret-key-in-production

# =====================================
# Server Configuration
# =====================================
HOST=0.0.0.0
PORT=5000

# =====================================
# Database Configuration
# =====================================
DATABASE_URL=sqlite:///org_visualizer.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# For MySQL: DATABASE_URL=mysql://user:password@localhost:3306/dbname
SQLALCHEMY_DATABASE_URI=${DATABASE_URL}
SQLALCHEMY_TRACK_MODIFICATIONS=false
SQLALCHEMY_ENGINE_OPTIONS_POOL_PRE_PING=true
SQLALCHEMY_ENGINE_OPTIONS_POOL_RECYCLE=300

# =====================================
# LDAP Configuration
# =====================================
LDAP_SERVER=ldap://localhost:389
LDAP_USER=cn=admin,dc=example,dc=com
LDAP_PASSWORD=admin
LDAP_BASE_DN=dc=example,dc=com
LDAP_TIMEOUT=30
LDAP_USE_TLS=false

# =====================================
# Jira Integration Configuration
# =====================================
JIRA_SERVER=https://your-company.atlassian.net
JIRA_USER=your-email@company.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ
JIRA_API_TIMEOUT=30
JIRA_MAX_RESULTS=1000

# =====================================
# Git Integration Configuration
# =====================================
GIT_SERVER=https://api.github.com
GIT_USERNAME=your-git-username
GIT_TOKEN=your-git-token
GIT_API_TIMEOUT=30
GIT_CLONE_TIMEOUT=300
GIT_TEMP_DIR=./temp/git

# =====================================
# File Upload Configuration
# =====================================
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=./uploads

# =====================================
# WebSocket Configuration
# =====================================
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_MAX_CLIENTS=100

# =====================================
# API Rate Limiting
# =====================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=1000 per hour

# =====================================
# CORS Configuration
# =====================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =====================================
# Logging Configuration
# =====================================
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# =====================================
# Cache Configuration
# =====================================
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# =====================================
# Performance Configuration
# =====================================
ENABLE_PROFILING=false
SLOW_QUERY_THRESHOLD=0.5

# =====================================
# Security Configuration
# =====================================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_ENABLED=true

# =====================================
# Analytics Configuration
# =====================================
ENABLE_ANALYTICS_TRACKING=false
ANALYTICS_RETENTION_DAYS=90

# =====================================
# Feature Flags
# =====================================
ENABLE_LDAP_SYNC=true
ENABLE_JIRA_INTEGRATION=true
ENABLE_GIT_INTEGRATION=true
ENABLE_WEBSOCKET=true
ENABLE_REAL_TIME_COLLABORATION=true

# =====================================
# Development/Debug Settings
# =====================================
# Uncomment for development
# FLASK_DEBUG=true
# LOG_LEVEL=DEBUG
# SESSION_COOKIE_SECURE=false

# =====================================
# Runtime Configuration Notes
# =====================================
# - Variables are loaded at application startup
# - Missing optional variables will use default values
# - Required variables: SECRET_KEY (production)
# - Check application logs for configuration warnings
# - For production deployment, ensure all security variables are properly set